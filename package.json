{
  "name": "devpulse-code",
  "displayName": "DevPulse - Activity Tracker",
  "description": "Beautiful coding activity tracker with live dashboard, GitHub-style heatmap, streak tracking, language stats & shareable cards. Privacy-first, works offline.",
  "version": "7.1.2",
  "publisher": "bistadev",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BistaDinesh03/devpulse-tracker"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "productivity",
    "tracking",
    "coding stats",
    "heatmap",
    "activity tracker",
    "streak",
    "developer tools",
    "code time",
    "wakatime alternative",
    "github contributions"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devpulse.showDashboard",
        "title": "DevPulse: Show Dashboard"
      },
      {
        "command": "devpulse.wrapped",
        "title": "DevPulse: Open Yearly Wrapped"
      },
      {
        "command": "devpulse.wrappedMonthly",
        "title": "DevPulse: Open Monthly Wrapped"
      },
      {
        "command": "devpulse.shareCard",
        "title": "DevPulse: Copy Share Card"
      },
      {
        "command": "devpulse.exportData",
        "title": "DevPulse: Export Data"
      }
    ],
    "configuration": {
      "title": "DevPulse",
      "properties": {
        "devpulse.goals.dailyTime": {
          "type": "number",
          "default": 240,
          "description": "Daily coding time goal (minutes)"
        },
        "devpulse.goals.dailyLines": {
          "type": "number",
          "default": 500,
          "description": "Daily lines written goal"
        },
        "devpulse.goals.dailySessions": {
          "type": "number",
          "default": 3,
          "description": "Daily focus sessions goal"
        },
        "devpulse.goals.weeklyTime": {
          "type": "number",
          "default": 1200,
          "description": "Weekly coding time goal (minutes)"
        },
        "devpulse.goals.weeklyDays": {
          "type": "number",
          "default": 5,
          "description": "Weekly days coded goal"
        },
        "devpulse.goals.monthlyTime": {
          "type": "number",
          "default": 4800,
          "description": "Monthly coding time goal (minutes)"
        },
        "devpulse.goals.monthlyDays": {
          "type": "number",
          "default": 20,
          "description": "Monthly days coded goal"
        },
        "devpulse.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show activity in status bar"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}